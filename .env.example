# ==========================================
# Epigrapher AI - Environment Configuration
# ==========================================

# ------------------------------------------
# Server Configuration
# ------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
ENABLE_DEBUG=true

# ------------------------------------------
# Security & Networking
# ------------------------------------------
CORS_ORIGIN=http://localhost:5173
# Comma-separated list of additional allowed origins if needed
# CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# ------------------------------------------
# API Keys & Secrets
# ------------------------------------------
# Gemini API Key (Required for AI Analysis)
GEMINI_API_KEY=

# ------------------------------------------
# Frontend Configuration (Vite)
# ------------------------------------------
# Any variable starting with VITE_ will be exposed to the client
VITE_API_URL=http://localhost:3001
VITE_APP_NAME="Epigrapher AI"
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false
